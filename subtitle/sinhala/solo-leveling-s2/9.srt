00:17:31,030 --> 00:17:33,910
<font size="34">මේ වැටලීමේ මෙහෙයුම අපි</font>
<font size="34">කාලෙක ඉදන් තියන් ඉදපු ඉලක්කයක්.</font>

223
00:17:33,910 --> 00:17:36,120
<font size="34">ඔයා කැමතිද අපට උදව් කරන්න</font>

224
00:17:37,870 --> 00:17:40,410
<font size="34">මේක ලෙවල් අප්වෙන්න හොදම අවස්ථාවක්.</font>

225
00:17:40,410 --> 00:17:41,880
<font size="34">මගඇරුනොත් අපරාදෙ</font>

226
00:17:42,750 --> 00:17:44,840
<font size="34">මම කලින් ඒ ගැන හිතුවා.</font>

227
00:17:49,880 --> 00:17:50,620
<font size="34">මම...</font>

228
00:17:52,800 --> 00:17:54,210
<font size="34">මායා බල තරංග?!</font>

229
00:17:55,760 --> 00:17:59,120
<font size="34">ඔයාට මෙච්චර දුර ඉදන් ඒක දැනුන</font>
<font size="34">එක නම් ඇත්තටම පුදුමයි.</font>

230
00:17:59,850 --> 00:18:04,390
<font size="34">S Rank  හන්ටර් ල</font>
<font size="34">ක්‍රීඩාගාරයේ ඉදන් පුහුනුවීම් කරනවා.</font>

231
00:18:04,860 --> 00:18:08,400
<font size="34">ඔයා කැමතිනම් </font>
<font size="34">ගිහින් බලන්න පුලුවන්</font>

232
00:18:22,120 --> 00:18:23,830
<font size="34">බීක් උපදේශක තුමා!</font>

233
00:18:23,830 --> 00:18:28,090
<font size="34">ඔයා තවම තරුණයි.නරකද තව ටිකක් ඔයාගෙ</font>
<font size="34">කකුල් වලයි පිටිපස්සෙයි ශක්තිය ගැන හිතුවොත්</font>

234
00:18:28,090 --> 00:18:31,840
<font size="34">මම දැනට ඔෆිස් එකක වැඩ කරන කෙනෙක්</font>
<font size="34">මා ඉන්ස්ට්‍රක්ටර් තුමා!</font>

235
00:18:33,350 --> 00:18:37,630
<font size="34">S Rank  හන්ටර් ල මෙහෙම එකතුවෙන්නෙ කලාතුරකින්</font>

236
00:18:38,260 --> 00:18:42,890
<font size="34">කලින් දැනුන මායා බල තරංග</font>
<font size="34">ආවෙ එයාලගෙන් වෙන්න ඕන.</font>

237
00:18:43,640 --> 00:18:45,770
<font size="34">හන්ට බීක් පරාද උනා වගේ නේද.</font>

238
00:18:45,770 --> 00:18:50,480
<font size="34">බීක් සභාපති තුමා සම්පූර්ණ ශක්තිය පාවිච්චි කලොත්</font>
<font size="34">හන්ටර් මා ට ඒක බොහෝදුරට දරාගන්න බැරි වේවි.</font>

239
00:18:51,110 --> 00:18:52,070
<font size="34">හලෝ.</font>

240
00:18:52,650 --> 00:18:57,080
<font size="34">ඔය ඩොබොක් එක ඇදන් ඉන්නෙ</font>
<font size="34">ෆේම් ගිල්ඩ් එකේ මා ඩොන්ග්වුක්.</font>

241
00:18:57,930 --> 00:19:00,240
<font size="34">ඇයි එයා සම්පූර්ණ ශක්තිය පාවිච්චි නොකරන්නේ?</font>

242
00:19:00,240 --> 00:19:03,620
<font size="34">එයාගෙ ප්‍රතිවාදියා අනුව එහෙම </font>
<font size="34">කරන්න ඕන කියල හිතෙන්නෙ නෑ</font>

243
00:19:03,620 --> 00:19:07,000
<font size="34">එයාගෙ ඇත්තම ශක්තිය හැමෝම ඉස්සරහ</font>
<font size="34">පෙන්නන එක එච්චර සුදුසු නෑ</font>

244
00:19:07,390 --> 00:19:11,710
<font size="34">එයා සම්පූර්ණ ශක්තිය පාවිච්චි කලොත්</font>
<font size="34">එයා ඇත්තටම මෘගයෙක් වෙනවා</font>

245
00:19:12,110 --> 00:19:14,840
<font size="34">ඒ කියන්නෙ එහෙම පෙනුම </font>
<font size="34">වෙනස් කරන හන්ටර් ල ගැන කතාව ඇත්තක්?.</font>

246
00:19:14,840 --> 00:19:19,220
<font size="34">ඒ වගේම අර අතන ඉන්න අය</font>
<font size="34">නයිට්ස් ගිල්ඩ් එකෙන්...</font>

247
00:19:21,140 --> 00:19:22,220
<font size="34">ඔහ්?</font>

248
00:19:22,220 --> 00:19:24,100
<font size="34">එයාලත් ඇවිල්ලද.</font>

249
00:19:25,560 --> 00:19:31,570
<font size="34"> අර එන්නෙ ජපානෙ S Rank හන්ටර් ල</font>
<font size="34">සහ ගිල්ඩ් මාස්ටර් ගොටෝ රියුජි</font>

250
00:19:31,910 --> 00:19:34,280
<font size="34">හ්ම්ම්..අර කවුද?</font>

251
00:19:34,740 --> 00:19:35,700
<font size="34">අහ්...</font>

252
00:19:35,700 --> 00:19:39,570
<font size="34">ඒ හන්ටර් සන්ග් ජින්වූ,</font>
<font size="34">ඉමේ ලගදි S Rank වලට ආවෙ එයා</font>

253
00:19:39,570 --> 00:19:41,490
<font size="34">පේන විදියට හුගක් දක්ශ ඇසැසින් කෙනෙක් වගේ</font>

254
00:19:41,960 --> 00:19:44,500
<font size="34">නෑ එයා මායාකරුවෙක්.</font>

255
00:19:46,830 --> 00:19:47,830
<font size="34">මායාකරුවෙක්?</font>

256
00:19:49,710 --> 00:19:50,710
<font size="34">ඔහ්?</font>

257
00:19:50,710 --> 00:19:55,300
<font size="34">අර අපේ මින්සන්ග් වත් අපහසුතාවට</font>
<font size="34">පත්කරපු හන්ටර් සන්ග් නේද?</font>

258
00:19:56,520 --> 00:19:58,790
<font size="34">වායුගෝලය(වටපිටාව) වෙනස් උන එක පුදුමයක් නෙවෙයි</font>

259
00:20:06,520 --> 00:20:08,730
<font size="34">ඒ කියන්නෙ එයාල මේ රටේ ප්‍රදානම සටන්කරුවො?.</font>

260
00:20:08,730 --> 00:20:09,900
<font size="34">ටිකක් විතර එපා උනා.</font>

261
00:20:10,440 --> 00:20:13,610
<font size="34">සමහර විට ඒ මම නිතරම</font>
<font size="34">ගොටෝ මහත්මයගෙ සටන් බලන නිසා වෙන්න ඇති</font>

262
00:20:13,610 --> 00:20:15,900
<font size="34">මට එයාලව කොහෙත්ම</font>
<font size="34">S-Rank වගේ පේන්නෙ නෑ</font>

263
00:20:15,900 --> 00:20:17,530
<font size="34">එහෙම හිතන්න තවම කලින් වැඩී</font>

264
00:20:17,530 --> 00:20:19,740
<font size="34">මට ඒ කතාව අහකදාන්න බෑ</font>

265
00:20:20,150 --> 00:20:21,160
<font size="34">පරිවර්ථක තුමියනි</font>

266
00:20:21,160 --> 00:20:23,450
<font size="34">ඔයා අපට අපහාස කලා නේද</font>

267
00:20:23,450 --> 00:20:25,500
<font size="34">ජැපනීස් වලින් කිව්ව උනත් මට ඒක කියන්න පුලුවන්.</font>

268
00:20:25,500 --> 00:20:27,080
<font size="34">නියමයි සභාපති තුමා</font>

269
00:20:27,510 --> 00:20:28,460
<font size="34">ඔයා...</font>

270
00:20:28,460 --> 00:20:31,540
<font size="34">මේ නයිට්ස් ගිල්ඩ් එකේ</font>
<font size="34">සභාපති තුමා</font>

271
00:20:31,540 --> 00:20:33,340
<font size="34">පාර්ක් ජොන්ග්සෝ.</font>

272
00:20:33,340 --> 00:20:34,630
<font size="34">පාක් ජොන්සෝ?</font>

273
00:20:34,630 --> 00:20:36,010
<font size="34">අදමයි ඇහුවෙත්.</font>

274
00:20:36,810 --> 00:20:40,010
<font size="34">අපේ ලොක්කා A Rank  හන්ටර් කෙනෙක්,</font>
<font size="34">S-Rank හන්ටර් කෙනෙක් නෙවෙයි</font>

275
00:20:40,010 --> 00:20:42,100
<font size="34">ඒ නිසා වෙන්න ඇති මං හිතන්නෙ</font>

276
00:20:42,100 --> 00:20:45,140
<font size="34">ඒත් අපි තාමත්</font>
<font size="34">මේ රටේ හොදම ගිල්ඩ් 5 අතරෙ ඉන්නවා</font>

277
00:20:45,140 --> 00:20:47,390
<font size="34">- වැටලීම් මෙහෙයුම අතරතුර...</font>
<font size="34">-මොකද ඔයාල කරන්නේ?</font>

278
00:20:47,390 --> 00:20:50,900
<font size="34">ඔයා ප්‍රශ්නයක් ඇති නොකලොත් හොදයි.</font>

279
00:20:50,900 --> 00:20:54,270
<font size="34">එයාල තමයි කිව්වෙ අපි දුර්වලයි කියල.</font>

280
00:20:54,650 --> 00:20:56,490
<font size="34">හරි හරි සන්සුන් වෙන්න.</font>

281
00:20:56,490 --> 00:20:57,690
<font size="34">වෙලාවටම ආවා</font>

282
00:20:58,010 --> 00:21:00,610
<font size="34">ඔයාල හැමෝම ඇවිල්ල ඉන්න නිසා,</font>
<font size="34">අපි සහයෝගිතා තරගයක් තියමු.</font>

283
00:21:00,610 --> 00:21:02,400
<font size="34">S Rank හන්ටර් ල විතරයි සහභාගි වෙන්නෝන.</font>

284
00:21:03,280 --> 00:21:05,160
<font size="34">ඔයා මාව අයින් කරනවද?!</font>

285
00:21:05,160 --> 00:21:08,470
<font size="34">ඔයාලට පුලුවන් තරග නීති තීරණය කරන්න.</font>

286
00:21:09,050 --> 00:21:10,290
<font size="34">ඒක හොදයි වගේ</font>

287
00:21:11,280 --> 00:21:17,300
<font size="34">මොකක් උනත් මායාකරුවන් ශක්තියෙන්  මනින්න බෑ,</font>
<font size="34">සටන් කරුවන් නොවන හන්ටර් ලත් අයින් කරන්න වෙනවා.</font>

